# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# OpenRouter API Key (get from https://openrouter.ai/)
OPENAI_API_KEY=your_openrouter_api_key_here

# Mistral AI API Key (optional backup provider — get from https://console.mistral.ai/)
# If OpenRouter is rate limited, bot will try Mistral automatically
MISTRAL_API_KEY=your_mistral_api_key_here

# LLM Model (optional - change primary OpenRouter model)
# Available free models: 
#   - google/gemma-4-26b-a4b-it:free (default)
#   - qwen/qwen3-next-80b-a3b-instruct:free
#   - meta-llama/llama-3.3-70b-instruct:free
LLM_MODEL=google/gemma-4-26b-a4b-it:free

# Database Configuration (defaults for Docker Compose)
DB_HOST=db
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=telegram_bot
